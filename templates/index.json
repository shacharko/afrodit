      "blocks": {
        "item_YhfjbX": {
          "type": "item",
          "settings": {
            "question": "How can I place an order?",
            "answer": "<p><strong>Orders can be placed directly through the website in a simple and convenient way. Our customer support team is also available via WhatsApp or by phone at +357 96 470670 for any assistance.</strong></p>"
          }
        },
        "item_ttYiCH": {
          "type": "item",
          "settings": {
            "question": "What is a decant and who is it for?",
            "answer": "<p><strong>A decant is a small bottle containing original perfume, carefully transferred directly from the brand’s official retail bottle.<br/>It allows you to experience the fragrance over time before committing to a full-size bottle.<br/><br/>Decants are perfect for anyone who wants to try a fragrance before buying, discover new scents, or enjoy a variety of perfumes without purchasing a full-size bottle.</strong></p>"
          }
        },
        "item_8F7YDE": {
          "type": "item",
          "settings": {
            "question": "Do decants come with a spray nozzle?",
            "answer": "<p><strong>Yes. All our decants come with a high-quality spray nozzle, ensuring a smooth and precise application.</strong></p>"
          }
        },
        "item_AcYc66": {
          "type": "item",
          "settings": {
            "question": "Are the perfumes in the decants authentic?",
            "answer": "<p><strong>Absolutely. All our decants contain 100% authentic, original fragrances — sourced directly from official brand bottles and carefully decanted.</strong></p>"
          }
        },
        "item_JTLYwF": {
          "type": "item",
          "settings": {
            "question": "What is the shelf life of a decant?",
            "answer": "<p><strong>The shelf life of a decant is approximately 4–6 months, provided it is stored in a cool, dry, and shaded place.<br/></strong></p>"
          }
        },
        "item_bhTeKb": {
          "type": "item",
          "settings": {
            "question": "How many uses does a decant provide?",
            "answer": "<p><strong>The number of sprays depends on the decant size:<br/>• 2 ml – approximately 30 sprays<br/>• 5 ml – approximately 75 sprays<br/>• 10 ml – approximately 150 sprays</strong></p>"
          }
        },
        "item_3BEBGR": {
          "type": "item",
          "settings": {
            "question": "Why should you try a fragrance before buying full size?",
            "answer": "<p><strong>* Avoid wasting money on a full-size bottle you might not love.<br/>* Experience the fragrance on your skin and see how it evolves over time.<br/>* Discover new scents and niche brands without commitment.<br/>* Perfect for travel, gifting, or building your own fragrance collection.</strong></p>"
          }
        },
        "item_MHD8Tz": {
          "type": "item",
          "settings": {
            "question": "How are the sets and discovery boxes curated, and what makes them special?",
            "answer": "<p><strong>At Afrodite, our discovery sets are carefully curated to match your personal style and preferences.<br/><br/>* Each set includes 5 handpicked fragrances, selected to create a balanced and unique scent experience.<br/>* Choose sets based on zodiac signs, seasons, scent profiles, moods, or specific brands.<br/>* Beautifully presented in luxurious packaging — perfect for gifting or personal indulgence.<br/>* Discover new fragrances the smart way, test them before committing to a full bottle, and avoid costly mistakes.</strong></p>"
          }
        },
        "item_gLz9kM": {
          "type": "item",
          "settings": {
            "question": "What is the return policy?",
            "answer": "<p><strong>Decants and testers are non-returnable due to their nature.<br/>Unopened full-size products, in their original packaging, can be returned within 14 days of purchase.</strong></p>"
          }
        }
